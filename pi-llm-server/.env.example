# mock or ollama
LLM_PROVIDER=mock

# Ollama settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Demo CORS
ALLOW_ORIGINS=*

# mock or qwen
TTS_PROVIDER=qwen

# Qwen TTS settings
TTS_MODEL=Qwen/Qwen3-TTS-12Hz-0.6B-Base
TTS_DEVICE=cuda:0
TTS_DTYPE=bfloat16
TTS_LANGUAGE=Korean
TTS_ATTN_IMPLEMENTATION=flash_attention_2
TTS_REF_AUDIO=/absolute/path/to/reference.wav
TTS_REF_TEXT=참조 음성에 들어있는 문장을 그대로 적어주세요.
